LIMIT 10;</sql><sql name="SQL 4">SELECT *
FROM sales
WHERE Sales &gt; 500;</sql><sql name="SQL 5">SELECT *
FROM sales
ORDER BY Sales DESC;</sql><sql name="SQL 6">SELECT Category,
SUM(Sales) AS TotalSales
FROM sales
GROUP BY Category;</sql><sql name="SQL 7">SELECT Category,
SUM(Sales) AS TotalSales
FROM sales
GROUP BY Category
HAVING SUM(Sales) &gt; 1000;</sql><sql name="SQL 8">SELECT *
FROM sales
WHERE Sales &gt;
(
SELECT AVG(Sales)
FROM sales
);</sql><sql name="SQL 9">WITH CustomerSales AS
(
SELECT &quot;Customer Name&quot;,
SUM(Sales) AS TotalSales
FROM sales
GROUP BY &quot;Customer Name&quot;
)

SELECT *
FROM CustomerSales
ORDER BY TotalSales DESC;</sql><sql name="SQL 35">SELECT name
FROM sqlite_master
WHERE type='table';</sql><sql name="SQL 36">SELECT * FROM sales
LIMIT 5;</sql><sql name="SQL 37">SELECT &quot;Customer Name&quot;,
