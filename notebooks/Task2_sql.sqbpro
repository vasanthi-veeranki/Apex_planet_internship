ROW_NUMBER() OVER
(
ORDER BY Sales DESC
) AS Rank
FROM sales;</sql><sql name="SQL 38">SELECT * FROM CategorySummary;</sql><sql name="SQL 39">SELECT Category,
SUM(Profit) AS TotalProfit
FROM sales
GROUP BY Category
ORDER BY TotalProfit DESC;</sql><sql name="SQL 40">SELECT Category,
SUM(Quantity) AS TotalQuantity
FROM sales
GROUP BY Category;</sql><sql name="SQL 41*">SELECT Region, SUM(Sales)
FROM sales
GROUP BY Region;

</sql><sql name="SQL 42*">SELECT Category, AVG(Profit)
